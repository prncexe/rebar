  "bin": {
    "rebar": "./bin/project.js"
  },
  "files": [
    "bin/",
    "src/",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalyco/rebar.git"
